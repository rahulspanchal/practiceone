<resources>

    <!-- Android 12+ splash screen. Uses the platform SplashScreen API so the
         branded Legaxy mark appears instantly on cold start (replacing the
         default launcher icon), then hands off to the JS splash. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <!-- Full design shows for the bulk of the cold start. -->
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <!-- Brief system splash (API mandatory): warm brand colour + small centred
             Legaxy logo, then hands off to the full design window background. -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
    </style>

</resources>
