<?xml version="1.0" encoding="utf-8"?>
<!-- Window background shown during the native->JS gap (after the system splash,
     while the JS bundle boots). It draws splash_full.png, which is a pixel-exact
     copy of the JS SplashView (same cover-scaled backdrop + same centred logo at
     0.62 of the screen width), so the gap is visually identical to the JS splash
     and the launch reads as one continuous splash with no flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/splash_background" />
    <item>
        <bitmap
            android:src="@drawable/splash_full"
            android:gravity="fill" />
    </item>
</layer-list>
